{
  "builds": [
    {
      "src": "nivix/api_server.py",
      "use": "@vercel/python"
    },
    {
      "src": "nivix/player/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "nivix/api_server.py"
    },
    {
      "src": "/(.*)",
      "dest": "nivix/player/index.html"
    }
  ]
}
